# Copy this file to `.env` and replace the placeholder values with your own secrets.
# The `.env` file is ignored by git so your credentials stay local.

# Microsoft Entra tenant (directory) ID.
GRAPH_TENANT_ID="00000000-0000-0000-0000-000000000000"

# Application (client) ID from Azure AD App registrations.
GRAPH_CLIENT_ID="00000000-0000-0000-0000-000000000000"

# Client secret created for the application registration.
GRAPH_CLIENT_SECRET="your-client-secret"

# Paste an active Microsoft Graph access token here. Tokens usually expire within an hour,
# so refresh this value before every run. A simple way to fetch it is with curl:
#   curl --location "https://login.microsoftonline.com/${GRAPH_TENANT_ID}/oauth2/token" \
#     --form "client_id=${GRAPH_CLIENT_ID}" \
#     --form "resource=https://graph.microsoft.com" \
#     --form "client_secret=${GRAPH_CLIENT_SECRET}" \
#     --form "grant_type=client_credentials"
GRAPH_BEARER_TOKEN="paste-hourly-access-token-here"

# The mailbox (user principal name or user ID) that will send the email.
GRAPH_USER_ID="sender@your-domain.example"

# Comma separated list of primary recipients.
GRAPH_TO_RECIPIENTS="recipient1@example.com,recipient2@example.com"

# Optional comma separated list of CC recipients. Leave blank to skip CC.
GRAPH_CC_RECIPIENTS=""

# Optional overrides for the demo email content.
GRAPH_MESSAGE_SUBJECT="Hello from Microsoft Graph"
GRAPH_MESSAGE_BODY="Hello world! This email was sent by a Python script that talks to Microsoft Graph."

# Whether the message should be stored in the sender's Sent Items folder (true/false).
GRAPH_SAVE_TO_SENT_ITEMS=false

# Override the Graph API base URL if you are targeting a different cloud.
GRAPH_API_BASE_URL="https://graph.microsoft.com/v1.0"
